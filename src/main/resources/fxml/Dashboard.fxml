<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #F4F6F8; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.DashboardController">

    <HBox alignment="CENTER_LEFT">
        <VBox>
            <Label text="Dashboard Utama Operasional" textFill="#1a1a1a">
                <font><Font name="System Bold" size="22.0" /></font>
            </Label>
            <Label text="Ringkasan cepat status perpustakaan" textFill="#7f8c8d" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Tampilkan Default (Hari Ini)"
                onAction="#handleTampilkanDefault"
                style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 4;" />
    </HBox>

    <HBox spacing="15.0">
        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="BUKU AKTIF" textFill="#7f8c8d" />
            <Label fx:id="lblBukuAktif" text="0" textFill="#2c3e50"><font><Font name="System Bold" size="24.0" /></font></Label>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="PEMINJAMAN HARI INI" textFill="#7f8c8d" />
            <Label fx:id="lblPeminjaman" text="0" textFill="#27ae60"><font><Font name="System Bold" size="24.0" /></font></Label>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="ANGGOTA AKTIF" textFill="#7f8c8d" />
            <Label fx:id="lblAnggota" text="0" textFill="#8e44ad"><font><Font name="System Bold" size="24.0" /></font></Label>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="TOTAL DENDA" textFill="#7f8c8d" />
            <Label fx:id="lblDenda" text="Rp 0" textFill="#c0392b"><font><Font name="System Bold" size="24.0" /></font></Label>
        </VBox>
    </HBox>

    <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="Tren Peminjaman Bulanan (Forecasting)" textFill="#2c3e50">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Tahun 2026" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-border-color: #ecf0f1; -fx-padding: 4 8; -fx-border-radius: 4;" />
        </HBox>
        <BarChart fx:id="barChartPeminjaman" VBox.vgrow="ALWAYS" legendVisible="false">
            <xAxis><CategoryAxis label="Bulan" /></xAxis>
            <yAxis><NumberAxis label="Jumlah Peminjaman" /></yAxis>
        </BarChart>
    </VBox>
</VBox>