<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.AnggotaController"
      spacing="15" style="-fx-padding: 20; -fx-background-color: white;" VBox.vgrow="ALWAYS">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Manajemen Anggota" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1B2A4A;"/>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" promptText="Cari ID / NIM / NIDN / NIS / Nama..." prefWidth="300"
                   style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
    </HBox>

    <TableView fx:id="tabelAnggota" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 6;">
        <columns>
            <TableColumn fx:id="colId" text="ID ANGGOTA" prefWidth="90" />
            <TableColumn fx:id="colNim" text="NIM / NIDN / NIS" prefWidth="140" />
            <TableColumn fx:id="colNama" text="NAMA LENGKAP" prefWidth="180" />
            <TableColumn fx:id="colTipe" text="TIPE" prefWidth="90" />
            <TableColumn fx:id="colBatas" text="BATAS PINJAM" prefWidth="100" />
            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="90" />
            <TableColumn fx:id="colOperasi" text="OPERASI" prefWidth="120" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>