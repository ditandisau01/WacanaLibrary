<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: #F4F6F8; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.AnggotaController">

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Manajemen Anggota" textFill="#1a1a1a">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" prefWidth="250.0" promptText="Cari ID / Nama / Tipe..." style="-fx-background-radius: 5;" />

        <Button onAction="#bukaFormTambahAnggota" style="-fx-background-color: #0056b3; -fx-text-fill: white; -fx-background-radius: 5;" text="+ Tambah Anggota" />
    </HBox>

    <TableView fx:id="tabelAnggota" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <columns>
            <TableColumn fx:id="colId" prefWidth="130.0" text="ID ANGGOTA" />
            <TableColumn fx:id="colNama" prefWidth="300.0" text="NAMA LENGKAP" />
            <TableColumn fx:id="colTipe" prefWidth="150.0" text="TIPE" />
            <TableColumn fx:id="colBatas" prefWidth="120.0" text="BATAS PINJAM" />
            <TableColumn fx:id="colStatus" prefWidth="120.0" text="STATUS" />

            <TableColumn fx:id="colOperasi" prefWidth="150.0" text="OPERASI" />
        </columns>
    </TableView>


</VBox>