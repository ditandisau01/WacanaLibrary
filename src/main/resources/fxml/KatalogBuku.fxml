<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.KatalogController"
      spacing="15" style="-fx-padding: 20; -fx-background-color: white;" VBox.vgrow="ALWAYS">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Katalog Digital" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1B2A4A;"/>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" promptText="Cari ID / Judul / Penulis / ISBN..." prefWidth="250"
                   style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
        <Button text="Tambah Buku" onAction="#bukaFormTambah"
                style="-fx-background-color: #185FA5; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 15;"/>
    </HBox>

    <TableView fx:id="tabelBuku" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 6;">
        <columns>
            <TableColumn fx:id="colGambar" text="SAMPUL" prefWidth="60" />
            <TableColumn fx:id="colId" text="ID BUKU" prefWidth="75" />
            <TableColumn fx:id="colIsbn" text="ISBN" prefWidth="110" />
            <TableColumn fx:id="colJudul" text="JUDUL BUKU" prefWidth="180" />
            <TableColumn fx:id="colPengarang" text="PENULIS" prefWidth="120" />
            <TableColumn fx:id="colKategori" text="KATEGORI" prefWidth="130" />
            <TableColumn fx:id="colTahun" text="TAHUN" prefWidth="65" />
            <TableColumn fx:id="colHalaman" text="HALAMAN" prefWidth="80" />
            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="90" />
            <TableColumn fx:id="colOperasi" text="OPERASI" prefWidth="120" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>