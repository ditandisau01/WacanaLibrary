<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: #F4F6F8; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.KatalogController">

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Katalog Digital" textFill="#1a1a1a">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" prefWidth="250.0" promptText="Cari ID / Judul / Penulis..." style="-fx-background-radius: 5;" />
        <Button fx:id="btnTambahBuku" onAction="#bukaFormTambah" style="-fx-background-color: #0056b3; -fx-text-fill: white; -fx-background-radius: 5;" text="+ Tambah Buku" />

    </HBox>

    <TableView fx:id="tabelBuku" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <columns>
            <TableColumn fx:id="colId" prefWidth="100.0" text="ID BUKU" />
            <TableColumn fx:id="colJudul" prefWidth="200.0" text="JUDUL BUKU" />
            <TableColumn fx:id="colPengarang" prefWidth="200.0" text="PENULIS" />
            <TableColumn fx:id="colKategori" prefWidth="150.0" text="KATEGORI" />

            <TableColumn fx:id="colTahun" prefWidth="80.0" text="TAHUN" />

            <TableColumn fx:id="colHalaman" prefWidth="80.0" text="HALAMAN" />

            <TableColumn fx:id="colStatus" prefWidth="100.0" text="STATUS" />
            <TableColumn fx:id="colOperasi" prefWidth="100.0" text="OPERASI" />
        </columns>
    </TableView>
</VBox>