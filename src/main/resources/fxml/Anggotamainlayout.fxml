<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.Anggotamaincontroller">

    <!-- SIDEBAR KIRI -->
    <left>
        <VBox prefWidth="250.0" spacing="8.0"
              style="-fx-background-color: #1B2A4A; -fx-border-color: #142038; -fx-border-width: 0 2 0 0;"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="30.0"/>
            </padding>

            <!-- Logo & Judul -->
            <Label text="📚 Wacana Library" textFill="white">
                <font><Font name="System Bold" size="16.0"/></font>
                <VBox.margin><Insets bottom="5.0"/></VBox.margin>
            </Label>
            <Label fx:id="lblNamaAnggota" text="Halo, Anggota!" textFill="#90CAF9">
                <font><Font size="12.0"/></font>
                <VBox.margin><Insets bottom="25.0"/></VBox.margin>
            </Label>

            <Separator style="-fx-background-color: #2E4070;">
                <VBox.margin><Insets bottom="10.0"/></VBox.margin>
            </Separator>

            <!-- Menu Navigasi -->
            <Button fx:id="btnDashboard" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: #2E4070; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 12 15;"
                    text="🏠  Dashboard" onAction="#showDashboard"/>

            <Button fx:id="btnKatalog" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #B0BEC5; -fx-background-radius: 6; -fx-padding: 12 15;"
                    text="📖  Katalog Buku" onAction="#showKatalog"/>

            <Button fx:id="btnRiwayat" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #B0BEC5; -fx-background-radius: 6; -fx-padding: 12 15;"
                    text="📋  Riwayat Pinjaman" onAction="#showRiwayat"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: #2E4070;">
                <VBox.margin><Insets bottom="10.0"/></VBox.margin>
            </Separator>

            <Button fx:id="btnKeluar" maxWidth="Infinity" alignment="BASELINE_LEFT"
                    style="-fx-text-fill: #EF9A9A; -fx-background-color: transparent; -fx-padding: 12 15;"
                    text="🚪  Keluar" onAction="#handleKeluar"/>
        </VBox>
    </left>

    <!-- AREA KONTEN UTAMA -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #F4F6F8;"
                   BorderPane.alignment="CENTER"/>
    </center>

</BorderPane>
