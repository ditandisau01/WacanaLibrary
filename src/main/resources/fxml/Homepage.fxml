<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.HomepageController">

    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 15 40; -fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
        <HBox alignment="CENTER_LEFT" spacing="0">
            <Label text="Wacana" textFill="#1B2A4A">
                <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            <Label text="Library" textFill="#185FA5">
                <font><Font name="System Bold" size="24.0" /></font>
            </Label>
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button text="Masuk" onAction="#handleLogin"
                style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #475569; -fx-font-size: 14; -fx-padding: 8 20; -fx-cursor: hand;" />
        <Button text="Daftar Sekarang" onAction="#handleRegister"
                style="-fx-background-color: #185FA5; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" />
    </HBox>

    <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: #F8FAFC; -fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0; -fx-control-inner-background: #F8FAFC;" VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="30.0" style="-fx-padding: 40 50; -fx-background-color: #F8FAFC;">

                <VBox alignment="CENTER" spacing="8.0">
                    <Label text="Temukan Buku Favoritmu" textFill="#1B2A4A">
                        <font><Font name="System Bold" size="32.0" /></font>
                    </Label>
                    <Label text="Jelajahi ribuan koleksi buku perpustakaan Wacana gratis untuk semua anggota" textFill="#64748B">
                        <font><Font size="14.0" /></font>
                    </Label>
                </VBox>

                <HBox alignment="CENTER" spacing="10.0">
                    <TextField fx:id="searchField" promptText="Cari judul, penulis, kategori, atau ISBN..." prefWidth="550.0"
                               style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14.0;" />
                    <Button onAction="#handleCariButton" text="× Reset" textFill="WHITE"
                            style="-fx-background-color: #64748B; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 12 20; -fx-cursor: hand;" />
                </HBox>

                <HBox alignment="CENTER" spacing="12.0">
                    <Button fx:id="chipSemua" onAction="#filterSemua" text="Semua"
                            style="-fx-background-color: #185FA5; -fx-text-fill: white; -fx-background-radius: 999; -fx-font-size: 13; -fx-padding: 8 20; -fx-cursor: hand;" />

                    <Button fx:id="chipSastra" onAction="#filterKategori" text="Sastra"
                            style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-border-color: #CBD5E1; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-size: 13; -fx-padding: 8 20; -fx-cursor: hand;" />

                    <Button fx:id="chipSains" onAction="#filterKategori" text="Ilmu Murni / Sains"
                            style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-border-color: #CBD5E1; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-size: 13; -fx-padding: 8 20; -fx-cursor: hand;" />

                    <Button fx:id="chipTeknologi" onAction="#filterKategori" text="Teknologi / Ilmu Terapan"
                            style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-border-color: #CBD5E1; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-size: 13; -fx-padding: 8 20; -fx-cursor: hand;" />

                    <Button fx:id="chipSejarah" onAction="#filterKategori" text="Sejarah &amp; Geografi"
                            style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-border-color: #CBD5E1; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-size: 13; -fx-padding: 8 20; -fx-cursor: hand;" />

                    <Button fx:id="chipBahasa" onAction="#filterKategori" text="Bahasa"
                            style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-border-color: #CBD5E1; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-size: 13; -fx-padding: 8 20; -fx-cursor: hand;" />
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Koleksi Buku" textFill="#1B2A4A">
                        <font><Font name="System Bold" size="18.0" /></font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblJumlahHasil" text="0 buku ditemukan" textFill="#94A3B8" />
                </HBox>

                <StackPane alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="bookGrid" hgap="25.0" vgap="25.0" prefWrapLength="1000.0" />

                    <VBox fx:id="emptyState" alignment="CENTER" spacing="10.0" visible="false" managed="false" style="-fx-padding: 40 0;">
                        <Label text="Buku tidak ditemukan" textFill="#94A3B8">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <Label text="Coba gunakan kata kunci pencarian yang lain." textFill="#CBD5E1" />
                    </VBox>
                </StackPane>

            </VBox>
        </content>
    </ScrollPane>
</VBox>