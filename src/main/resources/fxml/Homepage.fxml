<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.HomepageController"
            prefWidth="1100.0" prefHeight="720.0"
            style="-fx-background-color: #F0F4F8;">

    <!-- ═══════════════════════ NAVBAR ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: white;
                     -fx-border-color: #E2E8F0;
                     -fx-border-width: 0 0 1 0;"
              prefHeight="64">
            <padding><Insets left="32" right="32"/></padding>

            <!-- Logo -->
            <Label text="Wacana" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1B2A4A;"/>
            <Label text="Library" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #185FA5;"/>

            <Region HBox.hgrow="ALWAYS"/>
            <!-- Buttons -->
            <Button text="Masuk" onAction="#handleLogin"
                    style="-fx-background-color: transparent;
                           -fx-border-color: #CBD5E1;
                           -fx-border-radius: 6;
                           -fx-background-radius: 6;
                           -fx-text-fill: #1B2A4A;
                           -fx-font-size: 13;
                           -fx-cursor: hand;
                           -fx-padding: 8 20;">
                <HBox.margin><Insets right="10"/></HBox.margin>
            </Button>
            <Button text="Daftar Sekarang" onAction="#handleRegister"
                    style="-fx-background-color: #185FA5;
                           -fx-background-radius: 6;
                           -fx-text-fill: white;
                           -fx-font-size: 13;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;
                           -fx-padding: 8 20;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="0">

                <!-- ─── HERO SECTION ─── -->
                <VBox alignment="CENTER" spacing="12"
                      style="-fx-background-color: white; -fx-padding: 52 32 40 32;">
                    <Label text="Temukan Buku Favoritmu"
                           style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #1B2A4A;"/>
                    <Label text="Jelajahi ribuan koleksi buku perpustakaan Wacana gratis untuk semua anggota"
                           style="-fx-font-size: 14; -fx-text-fill: #64748B;"/>

                    <!-- Search Bar -->
                    <HBox alignment="CENTER" spacing="0" maxWidth="600"
                          style="-fx-background-color: white;
                                 -fx-border-color: #CBD5E1;
                                 -fx-border-radius: 10;
                                 -fx-background-radius: 10;
                                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 12, 0, 0, 4);">
                        <VBox.margin><Insets top="12" bottom="4"/></VBox.margin>
                        <Label text="🔍" style="-fx-font-size: 16; -fx-padding: 0 0 0 16;"/>
                        <TextField fx:id="searchField"
                                   promptText="Cari judul, penulis, atau kategori..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent;
                                          -fx-border-color: transparent;
                                          -fx-font-size: 14;
                                          -fx-padding: 12 12 12 10;"/>
                        <Button text="✕ Reset" onAction="#handleCariButton"
                                style="-fx-background-color: #64748B;
                                       -fx-text-fill: white;
                                       -fx-font-size: 13;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 0 8 8 0;
                                       -fx-padding: 12 24;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Filter Chips -->
                    <HBox spacing="8" alignment="CENTER">
                        <VBox.margin><Insets top="8"/></VBox.margin>
                        <Button fx:id="chipSemua" text="Semua" onAction="#filterSemua"
                                style="-fx-background-color: #185FA5; -fx-text-fill: white;
                                       -fx-background-radius: 999; -fx-font-size: 12;
                                       -fx-padding: 6 16; -fx-cursor: hand;"/>
                        <Button fx:id="chipSastra" text="Sastra" onAction="#filterKategori"
                                style="-fx-background-color: white; -fx-text-fill: #64748B;
                                       -fx-border-color: #CBD5E1; -fx-border-radius: 999;
                                       -fx-background-radius: 999; -fx-font-size: 12;
                                       -fx-padding: 6 16; -fx-cursor: hand;"/>
                        <Button fx:id="chipSains" text="Sains" onAction="#filterKategori"
                                style="-fx-background-color: white; -fx-text-fill: #64748B;
                                       -fx-border-color: #CBD5E1; -fx-border-radius: 999;
                                       -fx-background-radius: 999; -fx-font-size: 12;
                                       -fx-padding: 6 16; -fx-cursor: hand;"/>
                        <Button fx:id="chipTeknologi" text="Teknologi" onAction="#filterKategori"
                                style="-fx-background-color: white; -fx-text-fill: #64748B;
                                       -fx-border-color: #CBD5E1; -fx-border-radius: 999;
                                       -fx-background-radius: 999; -fx-font-size: 12;
                                       -fx-padding: 6 16; -fx-cursor: hand;"/>
                        <Button fx:id="chipSejarah" text="Sejarah" onAction="#filterKategori"
                                style="-fx-background-color: white; -fx-text-fill: #64748B;
                                       -fx-border-color: #CBD5E1; -fx-border-radius: 999;
                                       -fx-background-radius: 999; -fx-font-size: 12;
                                       -fx-padding: 6 16; -fx-cursor: hand;"/>
                        <Button fx:id="chipBahasa" text="Bahasa" onAction="#filterKategori"
                                style="-fx-background-color: white; -fx-text-fill: #64748B;
                                       -fx-border-color: #CBD5E1; -fx-border-radius: 999;
                                       -fx-background-radius: 999; -fx-font-size: 12;
                                       -fx-padding: 6 16; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-background-color: #1B2A4A; -fx-padding: 16 32; -fx-background-radius: 12;"> <VBox.margin>
                    <Insets top="20" right="32" bottom="20" left="32"/>
                </VBox.margin>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblTotalBuku" text="0"
                               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #60A5FA;"/>
                        <Label text="Total Buku" style="-fx-font-size: 11; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                    <Separator orientation="VERTICAL" style="-fx-background-color: #FFFFFF;"/>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblTersedia" text="0"
                               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #34D399;"/>
                        <Label text="Tersedia" style="-fx-font-size: 11; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                    <Separator orientation="VERTICAL" style="-fx-background-color: #FFFFFF;"/>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblDipinjam" text="0"
                               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #FBBF24;"/>
                        <Label text="Dipinjam" style="-fx-font-size: 11; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                    <Separator orientation="VERTICAL" style="-fx-background-color: #FFFFFF;"/>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblKategori" text="0"
                               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #C084FC;"/>
                        <Label text="Kategori" style="-fx-font-size: 11; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                </HBox>

                <!-- ─── CATALOG SECTION ─── -->
                <VBox spacing="16" style="-fx-padding: 28 32;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="📚" style="-fx-font-size: 16;"/>
                        <Label text="Koleksi Buku"
                               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1B2A4A;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblJumlahHasil" text=""
                               style="-fx-font-size: 12; -fx-text-fill: #94A3B8;"/>
                    </HBox>

                    <!-- Book Grid (FlowPane) -->
                    <FlowPane fx:id="bookGrid" hgap="14" vgap="14"
                              prefWrapLength="1040"
                              style="-fx-background-color: transparent;"/>

                    <!-- Empty State -->
                    <VBox fx:id="emptyState" alignment="CENTER" spacing="8"
                          style="-fx-padding: 60 0;"
                          visible="false" managed="false">
                        <Label text="📭" style="-fx-font-size: 40;"/>
                        <Label text="Tidak ada buku ditemukan"
                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                        <Label text="Coba kata kunci atau kategori lain"
                               style="-fx-font-size: 12; -fx-text-fill: #94A3B8;"/>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
