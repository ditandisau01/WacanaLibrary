<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.MainController">

    <left>
        <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: #F8F9FA; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
            </padding>
            <Label text="Sistem Perpustakaan" textFill="#2c3e50">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
                <VBox.margin>
                    <Insets bottom="30.0" />
                </VBox.margin>
            </Label>

            <Button fx:id="btnDashboard" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-padding: 10;" text="Dashboard" onAction="#showDashboard" />
            <Button fx:id="btnAnggota" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-padding: 10;" text="Anggota" onAction="#showAnggota" />
            <Button fx:id="btnKatalog" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: #E3F2FD; -fx-text-fill: #1976D2; -fx-background-radius: 5; -fx-padding: 10;" text="Katalog Buku" onAction="#showKatalog" />
            <Button fx:id="btnTransaksi" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-padding: 10;" text="Transaksi" onAction="#showTransaksi" />
            <Button fx:id="btnLaporan" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-padding: 10;" text="Laporan" onAction="#showLaporan" />


            <Region VBox.vgrow="ALWAYS" />
            <Button fx:id="btnKeluar" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-text-fill: red; -fx-background-color: transparent;" text="Keluar Sistem" onAction="#handleLogout" />
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: white;" BorderPane.alignment="CENTER" />
    </center>

</BorderPane>