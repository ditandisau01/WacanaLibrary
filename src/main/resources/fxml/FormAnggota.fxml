<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 25;" prefWidth="400.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.FormAnggotaController">

    <Label text="Pendaftaran Anggota Baru" textFill="#2c3e50">
        <font><Font name="System Bold" size="18.0" /></font>
    </Label>

    <VBox spacing="5.0">
        <Label text="NAMA LENGKAP" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
        <TextField fx:id="txtNama" promptText="Masukkan nama lengkap..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="TIPE ANGGOTA" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
        <ComboBox fx:id="cbTipe" maxWidth="Infinity" promptText="Pilih Tipe Anggota" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="STATUS" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
        <ComboBox fx:id="cbStatus" maxWidth="Infinity" />
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <padding><Insets top="15.0" /></padding>
        <Button text="Batal" onAction="#handleBatal" style="-fx-background-color: transparent; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-font-weight: bold;" />
        <Button text="Simpan Data" onAction="#handleSimpan" style="-fx-background-color: #0056b3; -fx-text-fill: white; -fx-background-radius: 4; -fx-font-weight: bold;" />
    </HBox>

</VBox>