<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 25;" prefWidth="500.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.FormBukuController">

    <Label text="Tambah Buku Baru" textFill="#2c3e50">
        <font><Font name="System Bold" size="18.0" /></font>
        <padding><Insets bottom="10.0" /></padding>
    </Label>

    <VBox spacing="5.0">
        <Label text="JUDUL BUKU" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
        <TextField fx:id="txtJudul" promptText="Masukkan judul buku..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="ISBN" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
        <TextField fx:id="txtIsbn" promptText="Masukkan ISBN..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="PENULIS" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
        <TextField fx:id="txtPenulis" promptText="Masukkan nama penulis..." />
    </VBox>

    <HBox spacing="15.0">
        <VBox HBox.hgrow="ALWAYS" spacing="5.0">
            <Label text="KATEGORI" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
            <ComboBox fx:id="cbKategori" maxWidth="Infinity" promptText="Pilih Kategori" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="5.0">
            <Label text="TAHUN TERBIT" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
            <TextField fx:id="txtTahun" promptText="YYYY" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="5.0">
            <Label text="HALAMAN" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
            <TextField fx:id="txtHalaman" promptText="Jumlah Hal..." />
        </VBox>
    </HBox>

    <VBox spacing="5.0">
        <Label text="GAMBAR BUKU" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
        <HBox spacing="10.0">
            <TextField fx:id="txtGambar" promptText="Pilih file gambar sampul..." editable="false" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9f9f9;" />
            <Button text="Pilih File" onAction="#handlePilihGambar" style="-fx-cursor: hand;" />
        </HBox>
    </VBox>

    <VBox spacing="5.0">
        <Label text="STATUS FISIK" textFill="#7f8c8d"><font><Font size="10.0" /></font></Label>
        <ComboBox fx:id="cbStatus" maxWidth="Infinity" />
        <Label text="Status awal buku baru secara default adalah 'Tersedia'." textFill="#bdc3c7"><font><Font size="10.0" /></font></Label>
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <padding><Insets top="15.0" /></padding>
        <Button text="Batal" onAction="#handleBatal" style="-fx-background-color: transparent; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-font-weight: bold; -fx-cursor: hand;" />
        <Button text="Simpan Data" onAction="#handleSimpan" style="-fx-background-color: #0056b3; -fx-text-fill: white; -fx-background-radius: 4; -fx-font-weight: bold; -fx-cursor: hand;" />
    </HBox>

</VBox>