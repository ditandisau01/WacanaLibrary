<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: #F4F6F8; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.AnggotaKatalogController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="📖 Katalog Buku" textFill="#1B2A4A">
            <font><Font name="System Bold" size="20.0"/></font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Hanya search, tidak ada tombol Tambah -->
        <TextField fx:id="searchField" prefWidth="280.0"
                   promptText="🔍  Cari judul, penulis, atau kategori..."
                   style="-fx-background-radius: 20; -fx-padding: 8 15;"
                   onKeyReleased="#handleCari"/>
    </HBox>

    <!-- TABEL BUKU (tanpa kolom OPERASI) -->
    <TableView fx:id="tabelBuku" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white; -fx-background-radius: 10;
                      -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 8, 0, 0, 3);">
        <columns>
            <TableColumn fx:id="colId"        prefWidth="100.0" text="ID BUKU"/>
            <TableColumn fx:id="colJudul"     prefWidth="220.0" text="JUDUL BUKU"/>
            <TableColumn fx:id="colPengarang" prefWidth="180.0" text="PENULIS"/>
            <TableColumn fx:id="colKategori"  prefWidth="160.0" text="KATEGORI"/>
            <TableColumn fx:id="colTahun"     prefWidth="80.0"  text="TAHUN"/>
            <TableColumn fx:id="colHalaman"   prefWidth="90.0"  text="HALAMAN"/>
            <TableColumn fx:id="colStatus"    prefWidth="110.0" text="STATUS"/>
        </columns>
        <placeholder>
            <Label text="Tidak ada buku ditemukan." textFill="#90A4AE"/>
        </placeholder>
    </TableView>

</VBox>
