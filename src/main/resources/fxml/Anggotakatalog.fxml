<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #F8FAFC; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.AnggotaKatalogController">

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Katalog Buku" textFill="#1B2A4A">
            <font><Font name="System Bold" size="24.0"/></font>
        </Label>

        <Region HBox.hgrow="ALWAYS"/>

        <TextField fx:id="searchField" prefWidth="350.0"
                   promptText="Cari judul, penulis, kategori, atau ISBN..."
                   style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10 15;"/>
    </HBox>

    <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <content>
            <FlowPane fx:id="bookGrid" hgap="20.0" vgap="20.0" style="-fx-padding: 10 0 0 0;">
            </FlowPane>
        </content>
    </ScrollPane>

</VBox>