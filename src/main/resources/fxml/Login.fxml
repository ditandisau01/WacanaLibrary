<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.LoginController"
      alignment="CENTER" spacing="20" style="-fx-padding: 40;">

    <Label text="Wacana Library" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    <Label text="Sistem Manajemen Perpustakaan" style="-fx-font-size: 14;"/>

    <Separator/>

    <!-- Form Login Admin -->
    <VBox spacing="10" maxWidth="300">
        <TextField fx:id="txtUsername" promptText="Username Admin"/>
        <PasswordField fx:id="txtPassword" promptText="Password"/>
        <Button text="Login sebagai Admin" onAction="#handleLoginAdmin"
                maxWidth="Infinity"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
    </VBox>

    <Label fx:id="lblError" style="-fx-text-fill: red;"
           visible="false" managed="false"/>

    <Separator/>

    <!-- Tombol langsung masuk sebagai Anggota -->
    <VBox spacing="6" alignment="CENTER">
        <Label text="Kamu seorang anggota perpustakaan?"/>
        <Button text="Masuk sebagai Anggota" onAction="#handleMasukAnggota"
                maxWidth="300"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
    </VBox>

</VBox>