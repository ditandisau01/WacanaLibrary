<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="368.0" prefWidth="375.0" spacing="25" style="-fx-padding: 40; -fx-background-color: white;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="id.ac.ukdw.rplbo.wacanalibrary.controllers.LoginController">

    <VBox alignment="CENTER" spacing="5">
        <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1B2A4A;" text="Wacana Library" />
        <Label style="-fx-font-size: 13; -fx-text-fill: #64748B;" text="Sistem Manajemen Perpustakaan" />
    </VBox>

    <Separator maxWidth="320" />

    <VBox maxWidth="320" spacing="15">
        <TextField fx:id="txtUsername" promptText="Masukkan NIM / NIDN / NIS" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0;                           -fx-border-radius: 6; -fx-background-radius: 6;                           -fx-font-size: 14; -fx-padding: 10 12;" />

        <PasswordField fx:id="txtPassword" promptText="Password" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0;                               -fx-border-radius: 6; -fx-background-radius: 6;                               -fx-font-size: 14; -fx-padding: 10 12;" />

        <Button maxWidth="Infinity" onAction="#handleLogin" style="-fx-background-color: #185FA5; -fx-text-fill: white;                        -fx-font-size: 15; -fx-font-weight: bold;                        -fx-background-radius: 6; -fx-padding: 12; -fx-cursor: hand;" text="Masuk">
            <VBox.margin>
                <Insets top="10" />
            </VBox.margin>
        </Button>
    </VBox>

    <Label fx:id="lblError" alignment="CENTER" managed="false" maxWidth="320" style="-fx-text-fill: #DC2626; -fx-font-size: 12;                   -fx-background-color: #FEF2F2; -fx-background-radius: 6;                   -fx-padding: 8 12; -fx-wrap-text: true;" visible="false" />

</VBox>
